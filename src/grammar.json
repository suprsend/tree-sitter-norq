{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "norq",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_line"
      }
    },
    "_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "directive_if_line"
        },
        {
          "type": "SYMBOL",
          "name": "directive_each_line"
        },
        {
          "type": "SYMBOL",
          "name": "directive_else_line"
        },
        {
          "type": "SYMBOL",
          "name": "directive_named_line"
        },
        {
          "type": "SYMBOL",
          "name": "directive_end_line"
        },
        {
          "type": "SYMBOL",
          "name": "frontmatter_delimiter"
        },
        {
          "type": "SYMBOL",
          "name": "heading_line"
        },
        {
          "type": "SYMBOL",
          "name": "code_fence"
        },
        {
          "type": "SYMBOL",
          "name": "horizontal_rule"
        },
        {
          "type": "SYMBOL",
          "name": "blank_line"
        },
        {
          "type": "SYMBOL",
          "name": "content_line"
        }
      ]
    },
    "frontmatter_delimiter": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "---[ \\t]*\\n"
        }
      }
    },
    "directive_if_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "TOKEN",
            "content": {
              "type": "PREC",
              "value": 10,
              "content": {
                "type": "PATTERN",
                "value": ":::[ \\t]+if[ \\t]+"
              }
            }
          },
          "named": true,
          "value": "directive_if_prefix"
        },
        {
          "type": "SYMBOL",
          "name": "condition_expr"
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "directive_each_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "TOKEN",
            "content": {
              "type": "PREC",
              "value": 10,
              "content": {
                "type": "PATTERN",
                "value": ":::[ \\t]+each[ \\t]+"
              }
            }
          },
          "named": true,
          "value": "directive_each_prefix"
        },
        {
          "type": "FIELD",
          "name": "collection",
          "content": {
            "type": "SYMBOL",
            "name": "path"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[ \\t]+"
                },
                {
                  "type": "ALIAS",
                  "content": {
                    "type": "STRING",
                    "value": "as"
                  },
                  "named": true,
                  "value": "keyword_as"
                },
                {
                  "type": "PATTERN",
                  "value": "[ \\t]+"
                },
                {
                  "type": "FIELD",
                  "name": "binding",
                  "content": {
                    "type": "SYMBOL",
                    "name": "identifier"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "directive_else_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 10,
        "content": {
          "type": "PATTERN",
          "value": ":::else[ \\t]*\\n"
        }
      }
    },
    "directive_named_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "directive_name_token"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[ \\t]+"
                },
                {
                  "type": "FIELD",
                  "name": "params",
                  "content": {
                    "type": "SYMBOL",
                    "name": "directive_params"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "directive_name_token": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 10,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": ":::[ \\t]+header"
            },
            {
              "type": "PATTERN",
              "value": ":::[ \\t]+footer"
            },
            {
              "type": "PATTERN",
              "value": ":::[ \\t]+action"
            },
            {
              "type": "PATTERN",
              "value": ":::[ \\t]+callout"
            },
            {
              "type": "PATTERN",
              "value": ":::[ \\t]+highlight"
            },
            {
              "type": "PATTERN",
              "value": ":::[ \\t]+hero"
            },
            {
              "type": "PATTERN",
              "value": ":::[ \\t]+fields"
            },
            {
              "type": "PATTERN",
              "value": ":::[ \\t]+fieldset"
            },
            {
              "type": "PATTERN",
              "value": ":::[ \\t]+centered"
            },
            {
              "type": "PATTERN",
              "value": ":::[ \\t]+columns"
            },
            {
              "type": "PATTERN",
              "value": ":::[ \\t]+raw"
            }
          ]
        }
      }
    },
    "directive_end_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 10,
        "content": {
          "type": "PATTERN",
          "value": ":::[ \\t]*\\n"
        }
      }
    },
    "directive_params": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "condition_expr": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "comparison_operator"
          },
          {
            "type": "SYMBOL",
            "name": "logical_operator"
          },
          {
            "type": "SYMBOL",
            "name": "negation_operator"
          },
          {
            "type": "SYMBOL",
            "name": "string_literal"
          },
          {
            "type": "SYMBOL",
            "name": "number_literal"
          },
          {
            "type": "SYMBOL",
            "name": "boolean_literal"
          },
          {
            "type": "SYMBOL",
            "name": "path"
          },
          {
            "type": "PATTERN",
            "value": "[ \\t]+"
          }
        ]
      }
    },
    "comparison_operator": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "=="
          },
          {
            "type": "STRING",
            "value": "!="
          },
          {
            "type": "STRING",
            "value": ">="
          },
          {
            "type": "STRING",
            "value": "<="
          },
          {
            "type": "STRING",
            "value": ">"
          },
          {
            "type": "STRING",
            "value": "<"
          }
        ]
      }
    },
    "logical_operator": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "&&"
          },
          {
            "type": "STRING",
            "value": "||"
          }
        ]
      }
    },
    "negation_operator": {
      "type": "STRING",
      "value": "!"
    },
    "string_literal": {
      "type": "PATTERN",
      "value": "\"[^\"]*\""
    },
    "number_literal": {
      "type": "PATTERN",
      "value": "\\d+(\\.\\d+)?"
    },
    "boolean_literal": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "true"
          },
          {
            "type": "STRING",
            "value": "false"
          }
        ]
      }
    },
    "heading_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "heading_marker"
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]+"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "expression"
              },
              {
                "type": "SYMBOL",
                "name": "raw_expression"
              },
              {
                "type": "SYMBOL",
                "name": "heading_text"
              }
            ]
          }
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "heading_marker": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "#{1,6}"
        }
      }
    },
    "heading_text": {
      "type": "PATTERN",
      "value": "[^\\n{]+"
    },
    "code_fence": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "```[^\\n]*\\n"
        }
      }
    },
    "horizontal_rule": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "(-{3,}|\\*{3,}|_{3,})[ \\t]*\\n"
        }
      }
    },
    "blank_line": {
      "type": "PATTERN",
      "value": "[ \\t]*\\n"
    },
    "content_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT1",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "expression"
              },
              {
                "type": "SYMBOL",
                "name": "raw_expression"
              },
              {
                "type": "SYMBOL",
                "name": "text_chunk"
              }
            ]
          }
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "text_chunk": {
      "type": "PATTERN",
      "value": "([^\\n{]|\\{[^\\n{])+"
    },
    "expression": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": "{{"
          },
          "named": true,
          "value": "expression_open"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "partial_ref"
            },
            {
              "type": "SYMBOL",
              "name": "expression_body"
            }
          ]
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": "}}"
          },
          "named": true,
          "value": "expression_close"
        }
      ]
    },
    "raw_expression": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": "{{{"
          },
          "named": true,
          "value": "raw_expression_open"
        },
        {
          "type": "SYMBOL",
          "name": "path"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": "}}}"
          },
          "named": true,
          "value": "raw_expression_close"
        }
      ]
    },
    "partial_ref": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": ">"
          },
          "named": true,
          "value": "partial_operator"
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        }
      ]
    },
    "expression_body": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "path"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "pipe_call"
          }
        }
      ]
    },
    "pipe_call": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": "|"
          },
          "named": true,
          "value": "pipe_operator"
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "pipe_name"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "FIELD",
            "name": "arg",
            "content": {
              "type": "SYMBOL",
              "name": "_pipe_arg"
            }
          }
        }
      ]
    },
    "pipe_name": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "capitalize"
          },
          {
            "type": "STRING",
            "value": "uppercase"
          },
          {
            "type": "STRING",
            "value": "lowercase"
          },
          {
            "type": "STRING",
            "value": "titlecase"
          },
          {
            "type": "STRING",
            "value": "truncate"
          },
          {
            "type": "STRING",
            "value": "trim"
          },
          {
            "type": "STRING",
            "value": "trim_start"
          },
          {
            "type": "STRING",
            "value": "trim_end"
          },
          {
            "type": "STRING",
            "value": "replace"
          },
          {
            "type": "STRING",
            "value": "append"
          },
          {
            "type": "STRING",
            "value": "prepend"
          },
          {
            "type": "STRING",
            "value": "default"
          },
          {
            "type": "STRING",
            "value": "pluralize"
          },
          {
            "type": "STRING",
            "value": "md5"
          },
          {
            "type": "STRING",
            "value": "split"
          },
          {
            "type": "STRING",
            "value": "count"
          },
          {
            "type": "STRING",
            "value": "join"
          },
          {
            "type": "STRING",
            "value": "unique"
          },
          {
            "type": "STRING",
            "value": "at"
          },
          {
            "type": "STRING",
            "value": "first"
          },
          {
            "type": "STRING",
            "value": "last"
          },
          {
            "type": "STRING",
            "value": "reverse"
          },
          {
            "type": "STRING",
            "value": "sort"
          },
          {
            "type": "STRING",
            "value": "slice"
          },
          {
            "type": "STRING",
            "value": "add"
          },
          {
            "type": "STRING",
            "value": "subtract"
          },
          {
            "type": "STRING",
            "value": "multiply"
          },
          {
            "type": "STRING",
            "value": "divide"
          },
          {
            "type": "STRING",
            "value": "round"
          },
          {
            "type": "STRING",
            "value": "mod"
          },
          {
            "type": "STRING",
            "value": "abs"
          },
          {
            "type": "STRING",
            "value": "ceil"
          },
          {
            "type": "STRING",
            "value": "floor"
          },
          {
            "type": "STRING",
            "value": "percent"
          },
          {
            "type": "STRING",
            "value": "number"
          },
          {
            "type": "STRING",
            "value": "currency"
          },
          {
            "type": "STRING",
            "value": "json"
          },
          {
            "type": "STRING",
            "value": "from_json"
          },
          {
            "type": "STRING",
            "value": "date"
          },
          {
            "type": "STRING",
            "value": "timezone"
          }
        ]
      }
    },
    "_pipe_arg": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[ \\t]+"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "string_literal"
            },
            {
              "type": "SYMBOL",
              "name": "number_literal"
            },
            {
              "type": "SYMBOL",
              "name": "path"
            }
          ]
        }
      ]
    },
    "path": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_.\\[\\]]*"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_-]*"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}